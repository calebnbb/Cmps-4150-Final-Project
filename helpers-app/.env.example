# Copy this to .env and fill in your values

# MongoDB connection string (from MongoDB Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/helpersdb?retryWrites=true&w=majority

# Session secret — use any long random string
SESSION_SECRET=change-me-to-something-secret-and-long

# Port (Render sets this automatically)
PORT=3000
