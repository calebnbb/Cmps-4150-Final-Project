<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>My Dashboard — Helpers</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('partials/nav') %>

  <div class="container">
    <div class="page-header">
      <h1>My Tasks</h1>
      <span style="color:#718096">Logged in as <strong><%= username %></strong></span>
    </div>

    <% if (error && error.length) { %>
      <div class="alert alert-error"><%= error[0] %></div>
    <% } %>
    <% if (success && success.length) { %>
      <div class="alert alert-success"><%= success[0] %></div>
    <% } %>

    <!-- Create new task form -->
    <div class="create-form">
      <h2>➕ Create New Task</h2>
      <form action="/tasks" method="POST">
        <div class="form-group">
          <label for="title">Task Title *</label>
          <input type="text" id="title" name="title" placeholder="e.g. Help set up the event hall" required />
        </div>
        <div class="form-group">
          <label for="description">Description (optional)</label>
          <textarea id="description" name="description" placeholder="What does this task involve?"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Create Task</button>
      </form>
    </div>

    <!-- Existing tasks -->
    <% if (tasks.length === 0) { %>
      <div class="empty">
        <div class="icon">📋</div>
        <p>You haven't created any tasks yet. Use the form above!</p>
      </div>
    <% } else { %>
      <% tasks.forEach(task => { %>
        <% if (task.active) { %>
          <div class="card">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:.5rem;">
              <div>
                <h2><%= task.title %></h2>
                <div class="meta">
                  Active &bull; <%= task.volunteers.length %> volunteer<%= task.volunteers.length !== 1 ? 's' : '' %>
                </div>
              </div>
              <form action="/tasks/<%= task._id %>/delete" method="POST"
                    onsubmit="return confirm('Remove this task?')">
                <button type="submit" class="btn btn-danger">Remove Task</button>
              </form>
            </div>

            <% if (task.description) { %>
              <p><%= task.description %></p>
            <% } %>

            <% if (task.volunteers.length > 0) { %>
              <div class="volunteer-list">
                <p style="font-weight:600; margin-bottom:.5rem; font-size:.88rem; color:#4a5568;">Volunteers:</p>
                <% task.volunteers.forEach(v => { %>
                  <div class="volunteer-item">
                    <span>📧 <%= v.identifier %></span>
                    <form action="/tasks/dismiss" method="POST" style="display:inline;">
                      <input type="hidden" name="taskId" value="<%= task._id %>" />
                      <input type="hidden" name="identifier" value="<%= v.identifier %>" />
                      <button type="submit" class="btn btn-danger"
                              onclick="return confirm('Dismiss this volunteer?')">
                        Dismiss
                      </button>
                    </form>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p style="color:#a0aec0; font-size:.88rem; margin-top:.6rem;">No volunteers yet.</p>
            <% } %>
          </div>
        <% } %>
      <% }) %>

      <!-- Inactive tasks section -->
      <% const inactive = tasks.filter(t => !t.active); %>
      <% if (inactive.length > 0) { %>
        <hr class="divider" />
        <h2 style="color:#a0aec0; font-size:1rem; margin-bottom:1rem;">Removed Tasks</h2>
        <% inactive.forEach(task => { %>
          <div class="card" style="opacity:.6; border-left: 4px solid #e2e8f0;">
            <h2><%= task.title %></h2>
            <div class="meta">Inactive</div>
          </div>
        <% }) %>
      <% } %>
    <% } %>
  </div>
</body>
</html>
